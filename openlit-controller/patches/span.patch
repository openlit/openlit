+				switch {
+				case s.GenAI.Custom.Request.Model != "":
+					return name + " " + s.GenAI.Custom.Request.Model
+				case s.GenAI.Custom.ResponseModel != "":
+					return name + " " + s.GenAI.Custom.ResponseModel
+				default:
+					return name
+				}
+			}
+		}
+
 		if s.Type == EventTypeHTTPClient && s.SubType == HTTPSubtypeAnthropic && s.GenAI != nil && s.GenAI.Anthropic != nil {
 			name := s.GenAI.Anthropic.Output.Type
 			if name != "" {
