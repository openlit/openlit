+	// the Custom*Messages fields below (the raw VendorOpenAI getters return the
+	// non-normalized OpenAI shape).
+	Custom                   *VendorOpenAI
+	CustomInputMessages      string
+	CustomOutputMessages     string
+	CustomSystemInstructions string
+	// Ollama native API (/api/chat, /api/generate). Distinct schema, own vendor.
+	Ollama *VendorOllama
+}
+
+// VendorOllama holds fields parsed from Ollama's native API responses
+// (/api/chat, /api/generate), which differ from the OpenAI wire format:
+// tokens are prompt_eval_count/eval_count and output text is message.content
+// or response.
+type VendorOllama struct {
+	Model        string
+	InputTokens  int
+	OutputTokens int
+	Operation    string
+	// Input/Output carry the serialized request messages and response content
+	// for the gen_ai.{input,output}.messages span attributes.
+	Input  string
+	Output string
 }
 
