 		return s.GenAI.Rerank.Output.GetTotalTokens()
 	}
 
+	if s.GenAI.Custom != nil {
+		return s.GenAI.Custom.Usage.GetInputTokens()
+	}
+
+	if s.GenAI.Ollama != nil {
+		return s.GenAI.Ollama.InputTokens
+	}
+
 	return 0
 }
 
@@ -1851,6 +1907,14 @@ func (s *Span) GenAIOutputTokens() int {
 		return s.GenAI.Embedding.GetOutputTokens()
 	}
 
+	if s.GenAI.Custom != nil {
+		return s.GenAI.Custom.Usage.GetOutputTokens()
